//@version=6
indicator(
     "EdgeFlow v0.2.0",
     shorttitle="EdgeFlow",
     overlay=true,
     max_boxes_count=500,
     max_lines_count=500,
     max_labels_count=500)


//====================================================
// EdgeFlow
// Version : v0.2.0
// Sprint  : 02
//
// Modules:
// - EMA Engine
// - Session Engine
// - Session Liquidity Engine
//
// Future:
// - Liquidity Sweep
// - Market Structure
// - FVG
// - Order Blocks
// - Alerts
//====================================================



//====================================================
// INPUTS
//====================================================



//====================================================
// EMA ENGINE
//====================================================

groupEMA = "📈 EMA Engine"


showEMA10 = input.bool(
     true,
     "Mostrar EMA 10",
     group=groupEMA)


showEMA21 = input.bool(
     true,
     "Mostrar EMA 21",
     group=groupEMA)


showEMA200 = input.bool(
     true,
     "Mostrar EMA 200",
     group=groupEMA)



ema10Color = input.color(
     color.orange,
     "Color EMA 10",
     group=groupEMA)


ema21Color = input.color(
     color.blue,
     "Color EMA 21",
     group=groupEMA)


ema200Color = input.color(
     color.red,
     "Color EMA 200",
     group=groupEMA)



ema10Width = input.int(
     2,
     "Grosor EMA 10",
     minval=1,
     maxval=5,
     group=groupEMA)


ema21Width = input.int(
     2,
     "Grosor EMA 21",
     minval=1,
     maxval=5,
     group=groupEMA)


ema200Width = input.int(
     3,
     "Grosor EMA 200",
     minval=1,
     maxval=5,
     group=groupEMA)



//====================================================
// SESSION ENGINE SETTINGS
//====================================================


groupSession = "🌎 Session Engine"


sessionTimezone = input.string(
     "America/New_York",
     "Zona horaria",
     group=groupSession)



showAsia = input.bool(
     true,
     "Mostrar Asia",
     group=groupSession)


asiaSession = input.session(
     "0000-0900",
     "Horario Asia",
     group=groupSession)



showLondon = input.bool(
     true,
     "Mostrar Londres",
     group=groupSession)


londonSession = input.session(
     "0800-1700",
     "Horario Londres",
     group=groupSession)



showNY = input.bool(
     true,
     "Mostrar Nueva York",
     group=groupSession)


nySession = input.session(
     "0930-1600",
     "Horario Nueva York",
     group=groupSession)



//====================================================
// LIQUIDITY ENGINE SETTINGS
//====================================================


groupLiquidity = "💧 Session Liquidity Engine"


showLiquidityLevels = input.bool(
     true,
     "Mostrar High / Low sesiones",
     group=groupLiquidity)



showLabels = input.bool(
     true,
     "Mostrar etiquetas",
     group=groupLiquidity)



maxHistoricalDays = input.int(
     20,
     "Máximo días históricos",
     minval=5,
     maxval=100,
     group=groupLiquidity)


//====================================================
// EMA ENGINE
//====================================================


ema10 = ta.ema(close,10)

ema21 = ta.ema(close,21)

ema200 = ta.ema(close,200)



plot(
     showEMA10 ? ema10 : na,
     title="EMA 10",
     color=ema10Color,
     linewidth=ema10Width)



plot(
     showEMA21 ? ema21 : na,
     title="EMA 21",
     color=ema21Color,
     linewidth=ema21Width)



plot(
     showEMA200 ? ema200 : na,
     title="EMA 200",
     color=ema200Color,
     linewidth=ema200Width)



//====================================================
// SESSION ENGINE
//====================================================


// Detectar sesiones activas

inAsia = not na(
     time(
          timeframe.period,
          asiaSession,
          sessionTimezone))


inLondon = not na(
     time(
          timeframe.period,
          londonSession,
          sessionTimezone))


inNY = not na(
     time(
          timeframe.period,
          nySession,
          sessionTimezone))



//====================================================
// SESSION LIQUIDITY ENGINE
//====================================================


//-------------------------
// ASIA VARIABLES
//-------------------------

var float asiaHigh = na
var float asiaLow = na

var int asiaStart = na


//-------------------------
// LONDON VARIABLES
//-------------------------

var float londonHigh = na
var float londonLow = na

var int londonStart = na


//-------------------------
// NEW YORK VARIABLES
//-------------------------

var float nyHigh = na
var float nyLow = na

var int nyStart = na



//====================================================
// RESET AND CAPTURE SESSIONS
//====================================================



//-------------------------
// ASIA
//-------------------------


if showAsia

    if inAsia and not inAsia[1]

        asiaHigh := high
        asiaLow := low
        asiaStart := bar_index


    if inAsia

        asiaHigh := math.max(
             asiaHigh,
             high)


        asiaLow := math.min(
             asiaLow,
             low)



//-------------------------
// LONDON
//-------------------------


if showLondon

    if inLondon and not inLondon[1]

        londonHigh := high
        londonLow := low
        londonStart := bar_index


    if inLondon

        londonHigh := math.max(
             londonHigh,
             high)


        londonLow := math.min(
             londonLow,
             low)




//-------------------------
// NEW YORK
//-------------------------


if showNY

    if inNY and not inNY[1]

        nyHigh := high
        nyLow := low
        nyStart := bar_index


    if inNY

        nyHigh := math.max(
             nyHigh,
             high)


        nyLow := math.min(
             nyLow,
             low)



//====================================================
// SESSION COMPLETE FLAGS
//====================================================


asiaCompleted = not inAsia and inAsia[1]

londonCompleted = not inLondon and inLondon[1]

nyCompleted = not inNY and inNY[1]



//====================================================
// LIQUIDITY VISUAL ENGINE
//====================================================


// Arrays para guardar históricos

var line[] asiaHighLines = array.new_line()
var line[] asiaLowLines = array.new_line()

var line[] londonHighLines = array.new_line()
var line[] londonLowLines = array.new_line()

var line[] nyHighLines = array.new_line()
var line[] nyLowLines = array.new_line()



var label[] liquidityLabels = array.new_label()



//====================================================
// CREACIÓN DE NIVELES HISTÓRICOS
//====================================================



//-------------------------
// ASIA LEVELS
//-------------------------


if asiaCompleted and showLiquidityLevels

    highLine = line.new(
         asiaStart,
         asiaHigh,
         bar_index,
         asiaHigh,
         extend=extend.right,
         color=color.blue,
         width=1)


    lowLine = line.new(
         asiaStart,
         asiaLow,
         bar_index,
         asiaLow,
         extend=extend.right,
         color=color.blue,
         width=1)



    array.push(
         asiaHighLines,
         highLine)


    array.push(
         asiaLowLines,
         lowLine)



    if showLabels

        labelHigh = label.new(
             bar_index,
             asiaHigh,
             "Asia High",
             style=label.style_label_left,
             textcolor=color.white)


        labelLow = label.new(
             bar_index,
             asiaLow,
             "Asia Low",
             style=label.style_label_left,
             textcolor=color.white)



        array.push(
             liquidityLabels,
             labelHigh)


        array.push(
             liquidityLabels,
             labelLow)





//-------------------------
// LONDON LEVELS
//-------------------------


if londonCompleted and showLiquidityLevels

    highLine = line.new(
         londonStart,
         londonHigh,
         bar_index,
         londonHigh,
         extend=extend.right,
         color=color.green,
         width=1)


    lowLine = line.new(
         londonStart,
         londonLow,
         bar_index,
         londonLow,
         extend=extend.right,
         color=color.green,
         width=1)



    array.push(
         londonHighLines,
         highLine)


    array.push(
         londonLowLines,
         lowLine)



    if showLabels

        labelHigh = label.new(
             bar_index,
             londonHigh,
             "London High",
             style=label.style_label_left)


        labelLow = label.new(
             bar_index,
             londonLow,
             "London Low",
             style=label.style_label_left)



        array.push(
             liquidityLabels,
             labelHigh)


        array.push(
             liquidityLabels,
             labelLow)





//-------------------------
// NEW YORK LEVELS
//-------------------------


if nyCompleted and showLiquidityLevels

    highLine = line.new(
         nyStart,
         nyHigh,
         bar_index,
         nyHigh,
         extend=extend.right,
         color=color.red,
         width=1)


    lowLine = line.new(
         nyStart,
         nyLow,
         bar_index,
         nyLow,
         extend=extend.right,
         color=color.red,
         width=1)



    array.push(
         nyHighLines,
         highLine)


    array.push(
         nyLowLines,
         lowLine)



    if showLabels

        labelHigh = label.new(
             bar_index,
             nyHigh,
             "NY High",
             style=label.style_label_left)


        labelLow = label.new(
             bar_index,
             nyLow,
             "NY Low",
             style=label.style_label_left)



        array.push(
             liquidityLabels,
             labelHigh)


        array.push(
             liquidityLabels,
             labelLow)




//====================================================
// HISTORICAL LIMIT CONTROL
//====================================================


while array.size(asiaHighLines) > maxHistoricalDays

    line.delete(
         array.shift(asiaHighLines))


while array.size(asiaLowLines) > maxHistoricalDays

    line.delete(
         array.shift(asiaLowLines))


while array.size(londonHighLines) > maxHistoricalDays

    line.delete(
         array.shift(londonHighLines))


while array.size(londonLowLines) > maxHistoricalDays

    line.delete(
         array.shift(londonLowLines))


while array.size(nyHighLines) > maxHistoricalDays

    line.delete(
         array.shift(nyHighLines))


while array.size(nyLowLines) > maxHistoricalDays

    line.delete(
         array.shift(nyLowLines))


//====================================================
// END EDGEFLOW v0.2.0
//====================================================
