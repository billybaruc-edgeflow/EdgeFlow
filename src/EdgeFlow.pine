//@version=6
indicator(
     "EdgeFlow v0.3.1",
     shorttitle="EdgeFlow",
     overlay=true,
     max_lines_count=500,
     max_labels_count=500)

//====================================================
// EdgeFlow v0.3.1
//====================================================

//----------------------------------------------------
// EMA ENGINE INPUTS
//----------------------------------------------------
groupEMA = "📈 EMA Engine"

showEMA10 = input.bool(true, "Mostrar EMA 10", group=groupEMA)
showEMA21 = input.bool(true, "Mostrar EMA 21", group=groupEMA)
showEMA200 = input.bool(true, "Mostrar EMA 200", group=groupEMA)

ema10Color = input.color(color.orange, "Color EMA 10", group=groupEMA)
ema21Color = input.color(color.blue, "Color EMA 21", group=groupEMA)
ema200Color = input.color(color.red, "Color EMA 200", group=groupEMA)
emaWidth = input.int(2, "Grosor EMA", minval=1, maxval=5, group=groupEMA)

//----------------------------------------------------
// SESSION ENGINE INPUTS
//----------------------------------------------------
groupSession = "🌎 Session Engine"

sessionTimezone = input.string("America/New_York", "Zona horaria", group=groupSession)

showAsia = input.bool(true, "Mostrar Asia", group=groupSession)
asiaSession = input.session("0000-0900", "Horario Asia", group=groupSession)

showLondon = input.bool(true, "Mostrar Londres", group=groupSession)
londonSession = input.session("0800-1700", "Horario Londres", group=groupSession)

showNY = input.bool(true, "Mostrar Nueva York", group=groupSession)
nySession = input.session("0930-1600", "Horario Nueva York", group=groupSession)

//----------------------------------------------------
// LIQUIDITY ENGINE INPUTS
//----------------------------------------------------
groupLiquidity = "💧 Session Liquidity Engine"

showLiquidity = input.bool(true, "Mostrar High / Low", group=groupLiquidity)
showLabels = input.bool(true, "Mostrar etiquetas", group=groupLiquidity)
lineWidth = input.int(1, "Grosor líneas", minval=1, maxval=3, group=groupLiquidity)
showHistorical = input.bool(false, "Mantener histórico", group=groupLiquidity)

//----------------------------------------------------
// SWEEP ENGINE INPUTS
//----------------------------------------------------
groupSweep = "⚡ Liquidity Sweep Engine"

showSweepAsia = input.bool(true, "Asia Sweeps", group=groupSweep)
showSweepLondon = input.bool(true, "London Sweeps", group=groupSweep)
showSweepNY = input.bool(true, "New York Sweeps", group=groupSweep)

sweepMode = input.string("cross-session", "Modo confirmación", options=["same-session", "cross-session"], group=groupSweep)
maxSweepCandles = input.int(3, "Máx velas confirmación", minval=1, maxval=10, group=groupSweep)
minPenetration = input.float(0.5, "Penetración mínima (pips)", minval=0.01, step=0.1, group=groupSweep)
showHistoricalSweeps = input.bool(false, "Mostrar históricos sweeps", group=groupSweep)
useTrendFilter = input.bool(true, "Filtro EMA 200", group=groupSweep)

//====================================================
// CALCULATIONS - EMA ENGINE
//====================================================
ema10 = ta.ema(close, 10)
ema21 = ta.ema(close, 21)
ema200 = ta.ema(close, 200)

plot(showEMA10 ? ema10 : na, "EMA 10", color=ema10Color, linewidth=emaWidth)
plot(showEMA21 ? ema21 : na, "EMA 21", color=ema21Color, linewidth=emaWidth)
plot(showEMA200 ? ema200 : na, "EMA 200", color=ema200Color, linewidth=emaWidth)

//====================================================
// SESSION DETECTION
//====================================================
inAsia = not na(time(timeframe.period, asiaSession, sessionTimezone))
inLondon = not na(time(timeframe.period, londonSession, sessionTimezone))
inNY = not na(time(timeframe.period, nySession, sessionTimezone))

//====================================================
// NEW DAY CONTROL
//====================================================
bool newDay = ta.change(time("D")) != 0

//====================================================
// SESSION VARIABLES
//====================================================
var float asiaHigh = na
var float asiaLow = na
var int asiaStartBar = na
var int asiaHighBar = na
var int asiaLowBar = na

var float londonHigh = na
var float londonLow = na
var int londonStartBar = na
var int londonHighBar = na
var int londonLowBar = na

var float nyHigh = na
var float nyLow = na
var int nyStartBar = na
var int nyHighBar = na
var int nyLowBar = na

//====================================================
// RESET DAILY VALUES
//====================================================
if newDay and not showHistorical
    asiaHigh := na
    asiaLow := na
    londonHigh := na
    londonLow := na
    nyHigh := na
    nyLow := na

//====================================================
// CAPTURE ASIA
//====================================================
if showAsia
    if inAsia and not inAsia[1]
        asiaHigh := high
        asiaLow := low
        asiaStartBar := bar_index
        asiaHighBar := bar_index
        asiaLowBar := bar_index

    if inAsia
        if high > asiaHigh
            asiaHigh := high
            asiaHighBar := bar_index
        if low < asiaLow
            asiaLow := low
            asiaLowBar := bar_index

//====================================================
// CAPTURE LONDON
//====================================================
if showLondon
    if inLondon and not inLondon[1]
        londonHigh := high
        londonLow := low
        londonStartBar := bar_index
        londonHighBar := bar_index
        londonLowBar := bar_index

    if inLondon
        if high > londonHigh
            londonHigh := high
            londonHighBar := bar_index
        if low < londonLow
            londonLow := low
            londonLowBar := bar_index

//====================================================
// CAPTURE NEW YORK
//====================================================
if showNY
    if inNY and not inNY[1]
        nyHigh := high
        nyLow := low
        nyStartBar := bar_index
        nyHighBar := bar_index
        nyLowBar := bar_index

    if inNY
        if high > nyHigh
            nyHigh := high
            nyHighBar := bar_index
        if low < nyLow
            nyLow := low
            nyLowBar := bar_index



//====================================================
// SESSION CLOSE EVENTS
//====================================================


asiaFinished = not inAsia and inAsia[1]

londonFinished = not inLondon and inLondon[1]

nyFinished = not inNY and inNY[1]



//====================================================
// LIQUIDITY VISUAL ENGINE v0.3.1
//====================================================


// Variables de líneas actuales

var line asiaHighLine = na
var line asiaLowLine = na

var line londonHighLine = na
var line londonLowLine = na

var line nyHighLine = na
var line nyLowLine = na



// Etiquetas de líneas

var label asiaHighLabel = na
var label asiaLowLabel = na

var label londonHighLabel = na
var label londonLowLabel = na

var label nyHighLabel = na
var label nyLowLabel = na



//====================================================
// DAILY CLEANUP
//====================================================


if newDay and not showHistorical

     if not na(asiaHighLine)
          line.delete(asiaHighLine)

     if not na(asiaLowLine)
          line.delete(asiaLowLine)


     if not na(londonHighLine)
          line.delete(londonHighLine)

     if not na(londonLowLine)
          line.delete(londonLowLine)


     if not na(nyHighLine)
          line.delete(nyHighLine)

     if not na(nyLowLine)
          line.delete(nyLowLine)



     if not na(asiaHighLabel)
          label.delete(asiaHighLabel)

     if not na(asiaLowLabel)
          label.delete(asiaLowLabel)


     if not na(londonHighLabel)
          label.delete(londonHighLabel)

     if not na(londonLowLabel)
          label.delete(londonLowLabel)


     if not na(nyHighLabel)
          label.delete(nyHighLabel)

     if not na(nyLowLabel)
          label.delete(nyLowLabel)



//====================================================
// UPDATE SESSION LEVELS
//====================================================

// ASIA
if showLiquidity and not na(asiaHigh)

     if na(asiaHighLine)
          asiaHighLine := line.new(bar_index, asiaHigh, bar_index, asiaHigh,
               color=color.blue,
               style=line.style_dotted,
               width=lineWidth)

     line.set_xy1(asiaHighLine, asiaStartBar, asiaHigh)
     line.set_xy2(asiaHighLine, bar_index, asiaHigh)


     if na(asiaLowLine)
          asiaLowLine := line.new(bar_index, asiaLow, bar_index, asiaLow,
               color=color.blue,
               style=line.style_dotted,
               width=lineWidth)

     line.set_xy1(asiaLowLine, asiaStartBar, asiaLow)
     line.set_xy2(asiaLowLine, bar_index, asiaLow)


// LONDON
if showLiquidity and not na(londonHigh)

     if na(londonHighLine)
          londonHighLine := line.new(bar_index, londonHigh, bar_index, londonHigh,
               color=color.green,
               style=line.style_dotted,
               width=lineWidth)

     line.set_xy1(londonHighLine, londonStartBar, londonHigh)
     line.set_xy2(londonHighLine, bar_index, londonHigh)


     if na(londonLowLine)
          londonLowLine := line.new(bar_index, londonLow, bar_index, londonLow,
               color=color.green,
               style=line.style_dotted,
               width=lineWidth)

     line.set_xy1(londonLowLine, londonStartBar, londonLow)
     line.set_xy2(londonLowLine, bar_index, londonLow)


// NEW YORK
if showLiquidity and not na(nyHigh)

     if na(nyHighLine)
          nyHighLine := line.new(bar_index, nyHigh, bar_index, nyHigh,
               color=color.red,
               style=line.style_dotted,
               width=lineWidth)

     line.set_xy1(nyHighLine, nyStartBar, nyHigh)
     line.set_xy2(nyHighLine, bar_index, nyHigh)


     if na(nyLowLine)
          nyLowLine := line.new(bar_index, nyLow, bar_index, nyLow,
               color=color.red,
               style=line.style_dotted,
               width=lineWidth)

     line.set_xy1(nyLowLine, nyStartBar, nyLow)
     line.set_xy2(nyLowLine, bar_index, nyLow)



//====================================================
// EXTEND LEVELS DURING NY SESSION
//====================================================


if inNY and showLiquidity

     if not na(asiaHighLine)
          line.set_x2(asiaHighLine, bar_index)

     if not na(asiaLowLine)
          line.set_x2(asiaLowLine, bar_index)


     if not na(londonHighLine)
          line.set_x2(londonHighLine, bar_index)

     if not na(londonLowLine)
          line.set_x2(londonLowLine, bar_index)



//====================================================
// SESSION LABELS - NEW v0.3.1
//====================================================

// ASIA HIGH LABEL
if showLabels and not na(asiaHigh)
     asiaHighLabelText = "Asia High\n" + str.tostring(asiaHigh, format.price)
     
     if na(asiaHighLabel)
          asiaHighLabel := label.new(
               bar_index,
               asiaHigh * 1.001,
               text=asiaHighLabelText,
               color=color.blue,
               textcolor=color.white,
               style=label.style_label_left,
               size=size.small)
     else
          label.set_text(asiaHighLabel, asiaHighLabelText)
          label.set_xy(asiaHighLabel, bar_index, asiaHigh * 1.001)

// ASIA LOW LABEL
if showLabels and not na(asiaLow)
     asiaLowLabelText = "Asia Low\n" + str.tostring(asiaLow, format.price)
     
     if na(asiaLowLabel)
          asiaLowLabel := label.new(
               bar_index,
               asiaLow * 0.999,
               text=asiaLowLabelText,
               color=color.blue,
               textcolor=color.white,
               style=label.style_label_left,
               size=size.small)
     else
          label.set_text(asiaLowLabel, asiaLowLabelText)
          label.set_xy(asiaLowLabel, bar_index, asiaLow * 0.999)

// LONDON HIGH LABEL
if showLabels and not na(londonHigh)
     londonHighLabelText = "London High\n" + str.tostring(londonHigh, format.price)
     
     if na(londonHighLabel)
          londonHighLabel := label.new(
               bar_index,
               londonHigh * 1.001,
               text=londonHighLabelText,
               color=color.green,
               textcolor=color.white,
               style=label.style_label_left,
               size=size.small)
     else
          label.set_text(londonHighLabel, londonHighLabelText)
          label.set_xy(londonHighLabel, bar_index, londonHigh * 1.001)

// LONDON LOW LABEL
if showLabels and not na(londonLow)
     londonLowLabelText = "London Low\n" + str.tostring(londonLow, format.price)
     
     if na(londonLowLabel)
          londonLowLabel := label.new(
               bar_index,
               londonLow * 0.999,
               text=londonLowLabelText,
               color=color.green,
               textcolor=color.white,
               style=label.style_label_left,
               size=size.small)
     else
          label.set_text(londonLowLabel, londonLowLabelText)
          label.set_xy(londonLowLabel, bar_index, londonLow * 0.999)

// NEW YORK HIGH LABEL
if showLabels and not na(nyHigh)
     nyHighLabelText = "NY High\n" + str.tostring(nyHigh, format.price)
     
     if na(nyHighLabel)
          nyHighLabel := label.new(
               bar_index,
               nyHigh * 1.001,
               text=nyHighLabelText,
               color=color.red,
               textcolor=color.white,
               style=label.style_label_left,
               size=size.small)
     else
          label.set_text(nyHighLabel, nyHighLabelText)
          label.set_xy(nyHighLabel, bar_index, nyHigh * 1.001)

// NEW YORK LOW LABEL
if showLabels and not na(nyLow)
     nyLowLabelText = "NY Low\n" + str.tostring(nyLow, format.price)
     
     if na(nyLowLabel)
          nyLowLabel := label.new(
               bar_index,
               nyLow * 0.999,
               text=nyLowLabelText,
               color=color.red,
               textcolor=color.white,
               style=label.style_label_left,
               size=size.small)
     else
          label.set_text(nyLowLabel, nyLowLabelText)
          label.set_xy(nyLowLabel, bar_index, nyLow * 0.999)



//====================================================
// SWEEP ENGINE v1.0
//====================================================

// Variables de estado de sweeps consumidos
var bool asiaHighSwept = false
var bool asiaLowSwept = false
var bool londonHighSwept = false
var bool londonLowSwept = false
var bool nyHighSwept = false
var bool nyLowSwept = false

// Labels para visualización
var label asiaHighSweepLabel = na
var label asiaLowSweepLabel = na
var label londonHighSweepLabel = na
var label londonLowSweepLabel = na
var label nyHighSweepLabel = na
var label nyLowSweepLabel = na

// Reset diarios
if newDay and not showHistoricalSweeps
     asiaHighSwept := false
     asiaLowSwept := false
     londonHighSwept := false
     londonLowSwept := false
     nyHighSwept := false
     nyLowSwept := false

     if not na(asiaHighSweepLabel)
          label.delete(asiaHighSweepLabel)
     if not na(asiaLowSweepLabel)
          label.delete(asiaLowSweepLabel)
     if not na(londonHighSweepLabel)
          label.delete(londonHighSweepLabel)
     if not na(londonLowSweepLabel)
          label.delete(londonLowSweepLabel)
     if not na(nyHighSweepLabel)
          label.delete(nyHighSweepLabel)
     if not na(nyLowSweepLabel)
          label.delete(nyLowSweepLabel)


// ===== ASIA HIGH SWEEP DETECTION =====
if showSweepAsia and not na(asiaHigh) and not asiaHighSwept
     bool wickAboveAsiaHigh = high > asiaHigh + (minPenetration * syminfo.mintick)
     
     if wickAboveAsiaHigh
          for i = 0 to math.min(maxSweepCandles - 1, bar_index - 1)
               if close[i] < asiaHigh
                   int score = 1
                    string trendBias = "Neutral"
                    
                    if useTrendFilter
                        if close > ema200
                            trendBias := "Bullish"
                        else
                            trendBias := "Bearish"
                    
                    if na(asiaHighSweepLabel)
                         asiaHighSweepLabel := label.new(
                              bar_index - i,
                              asiaHigh,
                              text="SWP",
                              color=color.blue,
                              textcolor=color.white,
                              style=label.style_center,
                              size=size.small,
                              tooltip="Asia High Sweep\nScore: " + str.tostring(score) + "\nTrend: " + trendBias)
                    
                    asiaHighSwept := true
                    break


// ===== ASIA LOW SWEEP DETECTION =====
if showSweepAsia and not na(asiaLow) and not asiaLowSwept
     bool wickBelowAsiaLow = low < asiaLow - (minPenetration * syminfo.mintick)
     
     if wickBelowAsiaLow
          for i = 0 to math.min(maxSweepCandles - 1, bar_index - 1)
               if close[i] > asiaLow
                    int score = 1
                    string trendBias = "Neutral"
                    
                    if useTrendFilter
                        if close > ema200
                            trendBias := "Bullish"
                        else
                            trendBias := "Bearish"
                    
                    if na(asiaLowSweepLabel)
                         asiaLowSweepLabel := label.new(
                              bar_index - i,
                              asiaLow,
                              text="SWP",
                              color=color.blue,
                              textcolor=color.white,
                              style=label.style_center,
                              size=size.small,
                              tooltip="Asia Low Sweep\nScore: " + str.tostring(score) + "\nTrend: " + trendBias)
                    
                    asiaLowSwept := true
                    break


// ===== LONDON HIGH SWEEP DETECTION =====
if showSweepLondon and not na(londonHigh) and not londonHighSwept
     bool wickAboveLondonHigh = high > londonHigh + (minPenetration * syminfo.mintick)
     
     if wickAboveLondonHigh
          for i = 0 to math.min(maxSweepCandles - 1, bar_index - 1)
               if close[i] < londonHigh
                    int score = 1
                    string trendBias = "Neutral"
                    
                    if useTrendFilter
                        if close > ema200
                            trendBias := "Bullish"
                        else
                            trendBias := "Bearish"
                    
                    if na(londonHighSweepLabel)
                         londonHighSweepLabel := label.new(
                              bar_index - i,
                              londonHigh,
                              text="SWP",
                              color=color.green,
                              textcolor=color.white,
                              style=label.style_center,
                              size=size.small,
                              tooltip="London High Sweep\nScore: " + str.tostring(score) + "\nTrend: " + trendBias)
                    
                    londonHighSwept := true
                    break


// ===== LONDON LOW SWEEP DETECTION =====
if showSweepLondon and not na(londonLow) and not londonLowSweptc
     bool wickBelowLondonLow = low < londonLow - (minPenetration * syminfo.mintick)
     
     if wickBelowLondonLow
          for i = 0 to math.min(maxSweepCandles - 1, bar_index - 1)
               if close[i] > londonLow
                    int score = 1
                    string trendBias = "Neutral"
                    
                    if useTrendFilter
                        if close > ema200
                            trendBias := "Bullish"
                        else
                            trendBias := "Bearish"
                    
                    if na(londonLowSweepLabel)
                         londonLowSweepLabel := label.new(
                              bar_index - i,
                              londonLow,
                              text="SWP",
                              color=color.green,
                              textcolor=color.white,
                              style=label.style_center,
                              size=size.small,
                              tooltip="London Low Sweep\nScore: " + str.tostring(score) + "\nTrend: " + trendBias)
                    
                    londonLowSwept := true
                    break


// ===== NEW YORK HIGH SWEEP DETECTION =====
if showSweepNY and not na(nyHigh) and not nyHighSwept
     bool wickAboveNYHigh = high > nyHigh + (minPenetration * syminfo.mintick)
     
     if wickAboveNYHigh
          for i = 0 to math.min(maxSweepCandles - 1, bar_index - 1)
               if close[i] < nyHigh
                    int score = 1
                    string trendBias = "Neutral"
                    
                    if useTrendFilter
                        if close > ema200
                            trendBias := "Bullish"
                        else
                            trendBias := "Bearish"
                    
                    if na(nyHighSweepLabel)
                         nyHighSweepLabel := label.new(
                              bar_index - i,
                              nyHigh,
                              text="SWP",
                              color=color.red,
                              textcolor=color.white,
                              style=label.style_center,
                              size=size.small,
                              tooltip="New York High Sweep\nScore: " + str.tostring(score) + "\nTrend: " + trendBias)
                    
                    nyHighSwept := true
                    break


// ===== NEW YORK LOW SWEEP DETECTION =====
if showSweepNY and not na(nyLow) and not nyLowSwept
     bool wickBelowNYLow = low < nyLow - (minPenetration * syminfo.mintick)
     
     if wickBelowNYLow
          for i = 0 to math.min(maxSweepCandles - 1, bar_index - 1)
               if close[i] > nyLow
                    int score = 1
                    string trendBias = "Neutral"
                    
                    if useTrendFilter
                        if close > ema200
                            trendBias := "Bullish"
                        else
                            trendBias := "Bearish"
                    
                    if na(nyLowSweepLabel)
                         nyLowSweepLabel := label.new(
                              bar_index - i,
                              nyLow,
                              text="SWP",
                              color=color.red,
                              textcolor=color.white,
                              style=label.style_center,
                              size=size.small,
                              tooltip="New York Low Sweep\nScore: " + str.tostring(score) + "\nTrend: " + trendBias)
                    
                    nyLowSwept := true
                    break


//====================================================
// END EDGEFLOW v0.3.1
//====================================================
