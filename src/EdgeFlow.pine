//@version=6 
indicator("EdgeFlow v0.4.0", overlay = true, max_lines_count = 500, max_labels_count = 500, max_boxes_count = 100)

//====================================================
// EDGEFLOW v0.4.0 - CORE ENGINE
//====================================================

//====================================================
// GENERAL SETTINGS
//====================================================
groupGeneral = "General"
showHistorical = input.bool(false, "Show Historical Sessions", group = groupGeneral)
showDashboard  = input.bool(false, "Show Dashboard", group = groupGeneral)

//====================================================
// MODULE 6B: LABELS CONFIGURATION INPUTS ⭐ NEW
//====================================================
groupLabels = "Session Labels Settings"
showLabels  = input.bool(true, "Show Session Labels", group = groupLabels)
labelSize   = input.string(size.normal, "Labels Size", options = [size.small, size.normal, size.large], group = groupLabels)
labelColorMode = input.string("Session Color", "Labels Color Mode", options = ["Session Color", "White", "Black"], group = groupLabels)

//====================================================
// EMA ENGINE SETTINGS
//====================================================
groupEMA = "Moving Averages"
showEMA10  = input.bool(true, "EMA 10", group = groupEMA)
showEMA21  = input.bool(true, "EMA 21", group = groupEMA)
showEMA200 = input.bool(true, "EMA 200", group = groupEMA)

//====================================================
// SESSION SETTINGS
//====================================================
groupSessions = "Trading Sessions"
showAsia   = input.bool(true, "Asia", group = groupSessions)
showLondon = input.bool(true, "London", group = groupSessions)
showNY     = input.bool(true, "New York", group = groupSessions)

// Horarios (Chile)
asiaSession   = input.session("2000-0600", "Asia", group = groupSessions)
londonSession = input.session("0400-0900", "London", group = groupSessions)
nySession     = input.session("0930-1700", "New York", group = groupSessions)

//====================================================
// COLORS
//====================================================
groupColors = "Colors"
asiaColor   = input.color(color.rgb(0,180,255), "Asia", group = groupColors)
londonColor = input.color(color.rgb(255,170,0), "London", group = groupColors)
nyColor     = input.color(color.rgb(255,70,70), "New York", group = groupColors)

//====================================================
// SWEEP SETTINGS
//====================================================
groupSweep = "Liquidity Sweep"
enableSweep = input.bool(true, "Enable Sweep Detection", group = groupSweep)
barsToConfirm = input.int(3, "Confirmation Bars", minval = 1, maxval = 10, group = groupSweep)
minPenetration = input.int(1, "Minimum Penetration (Ticks)", minval = 1, group = groupSweep)

//====================================================
// ARCHITECTURE: USER-DEFINED TYPES (STRUCTS)
//====================================================
// Expandimos el objeto para incluir las referencias de los Labels
type SessionData
    float highPrice
    float lowPrice
    int startBar
    int highBar
    int lowBar
    line highLine
    line lowLine
    label highLabel // ⭐ Agregar referencia visual High Label
    label lowLabel  // ⭐ Agregar referencia visual Low Label
    string statusHigh 
    string statusLow  

// Instanciamos los objetos de forma persistente para cada sesión
var SessionData asia   = SessionData.new(na, na, na, na, na, na, na, na, na, "active", "active")
var SessionData london = SessionData.new(na, na, na, na, na, na, na, na, na, "active", "active")
var SessionData ny     = SessionData.new(na, na, na, na, na, na, na, na, na, "active", "active")

//====================================================
// MODULE 2: EMA ENGINE
//====================================================
ema10 = ta.ema(close, 10)
ema21 = ta.ema(close, 21)
ema200 = ta.ema(close, 200)

plot(showEMA10 ? ema10 : na, title="EMA 10", color=color.rgb(0,170,255), linewidth=2)
plot(showEMA21 ? ema21 : na, title="EMA 21", color=color.rgb(255,210,0), linewidth=2)
plot(showEMA200 ? ema200 : na, title="EMA 200", color=color.rgb(255,110,90), linewidth=3)

//====================================================
// MODULE 3: SESSION ENGINE DETECTION
//====================================================
inAsia   = not na(time(timeframe.period, asiaSession))
inLondon = not na(time(timeframe.period, londonSession))
inNY     = not na(time(timeframe.period, nySession))

asiaStarted   = inAsia and not inAsia[1]
londonStarted = inLondon and not inLondon[1]
nyStarted     = inNY and not inNY[1]

bool newDay = ta.change(time("D")) != 0

// Reset de estructuras al iniciar el día (si no se requiere histórico)
if newDay and not showHistorical
    asia.highPrice := na, asia.lowPrice := na, asia.startBar := na, asia.highBar := na, asia.lowBar := na
    asia.highLine := na, asia.lowLine := na, asia.highLabel := na, asia.lowLabel := na, asia.statusHigh := "active", asia.statusLow := "active"
    
    london.highPrice := na, london.lowPrice := na, london.startBar := na, london.highBar := na, london.lowBar := na
    london.highLine := na, london.lowLine := na, london.highLabel := na, london.lowLabel := na, london.statusHigh := "active", london.statusLow := "active"
    
    ny.highPrice := na, ny.lowPrice := na, ny.startBar := na, ny.highBar := na, ny.lowBar := na
    ny.highLine := na, ny.lowLine := na, ny.highLabel := na, ny.lowLabel := na, ny.statusHigh := "active", ny.statusLow := "active"

//====================================================
// MODULE 4: SESSION HIGH / LOW ENGINE
//====================================================
if showAsia
    if asiaStarted
        asia.highPrice := high, asia.lowPrice := low
        asia.startBar := bar_index, asia.highBar := bar_index, asia.lowBar := bar_index
        asia.statusHigh := "active", asia.statusLow := "active"
    if inAsia
        if high > nz(asia.highPrice, 0.0)
            asia.highPrice := high
            asia.highBar := bar_index
        if low < nz(asia.lowPrice, 999999.0)
            asia.lowPrice := low
            asia.lowBar := bar_index

if showLondon
    if londonStarted
        london.highPrice := high, london.lowPrice := low
        london.startBar := bar_index, london.highBar := bar_index, london.lowBar := bar_index
        london.statusHigh := "active", london.statusLow := "active"
    if inLondon
        if high > nz(london.highPrice, 0.0)
            london.highPrice := high
            london.highBar := bar_index
        if low < nz(london.lowPrice, 999999.0)
            london.lowPrice := low
            london.lowBar := bar_index

if showNY
    if nyStarted
        ny.highPrice := high, ny.lowPrice := low
        ny.startBar := bar_index, ny.highBar := bar_index, ny.lowBar := bar_index
        ny.statusHigh := "active", ny.statusLow := "active"
    if inNY
        if high > nz(ny.highPrice, 0.0)
            ny.highPrice := high
            ny.highBar := bar_index
        if low < nz(ny.lowPrice, 999999.0)
            ny.lowPrice := low
            ny.lowBar := bar_index

//====================================================
// MODULE 6A & 6B: DYNAMIC LIQUIDITY & LABELS ENGINE
//====================================================
// Función reutilizable para gestionar el color personalizado de la etiqueta
getLabelColor(color sessionColor) =>
    labelColorMode == "Session Color" ? sessionColor : labelColorMode == "White" ? color.white : color.black

getLabelTextColor(color sessionColor) =>
    labelColorMode == "Session Color" ? color.white : labelColorMode == "White" ? color.black : color.white

// Función maestra optimizada para actualizar líneas e introducir las etiquetas en el extremo derecho
updateDynamicLiquidityAndLabels(SessionData session, color sessionColor, string sessionName) =>
    if not na(session.highPrice)
        // Control de Históricos: Borrado preventivo en la vela actual si showHistorical es falso
        if not showHistorical
            line.delete(session.highLine)
            line.delete(session.lowLine)
            label.delete(session.highLabel)
            label.delete(session.lowLabel)
        else if (bar_index == session.startBar)
            session.highLine := na, session.lowLine := na
            session.highLabel := na, session.lowLabel := na

        // MÓDULO 6A: Renderizado Dinámico Infinito de Líneas hacia 'bar_index'
        session.highLine := line.new(session.highBar, session.highPrice, bar_index, session.highPrice, color = sessionColor, style = line.style_dashed, width = 2)
        session.lowLine  := line.new(session.lowBar, session.lowPrice, bar_index, session.lowPrice, color = sessionColor, style = line.style_dashed, width = 2)

        // MÓDULO 6B: Renderizado Dinámico de Etiquetas Profesionales en la punta derecha
        if showLabels
            actualLabelColor = getLabelColor(sessionColor)
            actualTextColor  = getLabelTextColor(sessionColor)
            
            session.highLabel := label.new(
                 x = bar_index + 2, 
                 y = session.highPrice, 
                 text = sessionName + " High", 
                 color = actualLabelColor, 
                 textcolor = actualTextColor, 
                 style = label.style_label_left, 
                 size = labelSize)
                 
            session.lowLabel := label.new(
                 x = bar_index + 2, 
                 y = session.lowPrice, 
                 text = sessionName + " Low", 
                 color = actualLabelColor, 
                 textcolor = actualTextColor, 
                 style = label.style_label_left, 
                 size = labelSize)

// Ejecución centralizada y limpia del motor unificado
updateDynamicLiquidityAndLabels(asia, asiaColor, "Asia")
updateDynamicLiquidityAndLabels(london, londonColor, "London")
